{
  "version": 2,
  "outputDirectory": "docs",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD docs/ vercel.json || exit 1"
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://kfc.brmkweb.cn"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, HEAD, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "*"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/[^.]+",
      "dest": "/index.html"
    }
  ]
}